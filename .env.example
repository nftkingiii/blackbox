PORT=3000

# Local storage is used by default.
# Set ZERO_G_STORAGE=true after installing dependencies and adding a funded 0G testnet key.
ZERO_G_STORAGE=false
ZERO_G_STORAGE_STRICT=true
ZERO_G_STORAGE_REQUIRED=false
ZERO_G_PRIVATE_KEY=your_0g_testnet_private_key_here
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_EXPLORER_TX_URL=https://chainscan-galileo.0g.ai/tx/{txHash}
ZERO_G_STORAGE_EXPLORER_URL=https://storagescan-galileo.0g.ai
ZERO_G_UPLOAD_TIMEOUT_MS=45000

# Galileo wallet, sponsored gas, and multiplayer escrow.
ZERO_G_EXPLORER_URL=https://chainscan-galileo.0g.ai
ZERO_G_FAUCET_URL=https://faucet.0g.ai
ZERO_G_TREASURY_PRIVATE_KEY=your_separate_testnet_treasury_private_key
ZERO_G_WELCOME_AMOUNT=0.005
ZERO_G_TREASURY_BOOTSTRAP_AMOUNT=0.5
BLACKBOX_OPERATOR_PRIVATE_KEY=your_separate_escrow_operator_private_key
BLACKBOX_OPERATOR_BOOTSTRAP_AMOUNT=0.2
BLACKBOX_ESCROW_ADDRESS=deploy_with_npm_run_deploy_escrow
BLACKBOX_STORY_VERSION=v3
BLACKBOX_ANSWER_PEPPER=generate_a_long_random_secret_for_answer_commitments
